{
  "name": "aipehub",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "AI + Person + Hub — a framework for orchestrating agent clusters and humans as collaborative participants.",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "demo": "pnpm --filter @aipehub/example-hello-collab start",
    "demo:web": "pnpm --filter @aipehub/example-web-demo start",
    "demo:broadcast": "pnpm --filter @aipehub/example-broadcast-claim start",
    "demo:persist:fresh": "pnpm --filter @aipehub/example-persist-and-resume start fresh",
    "demo:persist:resume": "pnpm --filter @aipehub/example-persist-and-resume start resume",
    "demo:persist:sqlite:fresh": "pnpm --filter @aipehub/example-persist-and-resume start fresh --sqlite",
    "demo:persist:sqlite:resume": "pnpm --filter @aipehub/example-persist-and-resume start resume --sqlite",
    "demo:remote": "pnpm --filter @aipehub/example-remote-agent start",
    "demo:remote:python": "pnpm --filter @aipehub/example-remote-python start",
    "demo:llm": "pnpm --filter @aipehub/example-llm-mock start",
    "demo:llm:real": "pnpm --filter @aipehub/example-llm-real start",
    "demo:cli-human": "pnpm --filter @aipehub/example-cli-human start",
    "demo:open-space": "pnpm --filter @aipehub/example-open-space start",
    "demo:federated-team": "pnpm --filter @aipehub/example-federated-team start",
    "host": "pnpm --filter @aipehub/host start",
    "test": "pnpm -r test",
    "test:python": "cd python-sdk && .venv/bin/python -m pytest -q",
    "test:all": "pnpm -r test && pnpm -r typecheck && pnpm test:python"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "@types/node": "^25.9.1",
    "tsx": "^4.22.0"
  },
  "pnpm": {
    "//": "Audit-fix overrides — force transitive vite/esbuild to the patched majors so vitest's dev-server tree can't hit GHSA-4w7w-66w2-5vf9 (vite .map path traversal) or GHSA-67mh-4wv8-2f99 (esbuild dev-server CORS). Tree is dev-only — production binary is unaffected — but devs running `pnpm test` shouldn't have a known-vulnerable dev server. Remove this block when vitest's vite peer floor rises past 6.4.2 organically.",
    "overrides": {
      "vite": "^6.4.2",
      "esbuild": "^0.25.0"
    }
  }
}
