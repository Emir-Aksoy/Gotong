# ── Gotong 配置模板 · 拓扑 T1：家用主机 = hub 本体，成员经 IM 接入 ──
#
# 用法：
#   cp deploy/.env.home .env.local        # .env.local 已被 .gitignore，放真 token 安全
#   # 编辑下面的值（至少填 GOTONG_TELEGRAM_BOT_TOKEN）
#   set -a; . ./.env.local; set +a && pnpm host
#   # 或交给 launchd(macOS) / systemd 的 EnvironmentFile 加载
#
# 完整说明：docs/zh/GO-LIVE.md（拓扑决策 + 成员绑定流程 + 风险）。
# 通用环境变量表：docs/zh/DEPLOY.md。
#
# ★ 这一档的核心 ★ 主机绑在 loopback，对公网【零暴露】。成员不直连，
# 而是私信你的 Telegram 机器人 —— IM 桥是「出站长轮询」，不需要任何
# 端口转发 / 内网穿透 / 公网 IP。家里路由器 NAT 后面的电脑直接能用。
# 不需要 TLS、不需要 Caddy、不需要域名。

# ── 工作区 ──────────────────────────────────────────────────────
GOTONG_SPACE=./.gotong                 # 状态目录（首次运行自动创建；整目录 = 你的房间）
GOTONG_SPACE_NAME="我的 Gotong"           # 仅首次初始化时写入 space.json
GOTONG_ADMIN_DISPLAY_NAME=我             # 第一个 admin 的显示名（仅首次初始化）

# ── 绑定 ────────────────────────────────────────────────────────
# loopback：只有这台机器上的浏览器能开 /admin。要让同网段设备也能开
# admin UI，看 GO-LIVE.md 的「T1 变体：LAN」（需额外两个开关）。
GOTONG_HOST=127.0.0.1
GOTONG_WEB_PORT=3000                    # 浏览器 + admin API
GOTONG_WS_PORT=4000                    # remote agent 的 WebSocket（家用通常用不上）

# ── 准入 ────────────────────────────────────────────────────────
GOTONG_GATING=admin-approval           # 新 agent 要你批准才接入（保持，别用 open）
GOTONG_COOKIE_SECURE=0                 # loopback 明文、admin 只在本机开 → 0 即可

# ── IM 接入：成员的入口 ★ T1 的关键 ★ ───────────────────────────
# 填任意一个或多个官方桥的凭证即接通（全部留空 = IM 关闭，主机行为
# 逐字节不变）。成员在 /me 生成 6 位绑定码 → 私信机器人 `/bind <码>`
# 即登录，之后自由文本直接对话。各桥申请步骤见 docs/zh/IM-BRIDGES.md。
#
# Telegram（@BotFather /newbot 拿 token；出站长轮询，免穿透）：
GOTONG_TELEGRAM_BOT_TOKEN=             # 例 123456789:AAH...（真 token 放 .env.local，勿提交）
# 飞书 / Lark（开放平台建「企业自建应用」，官方长连接，免穿透）：
GOTONG_LARK_APP_ID=                    # 例 cli_xxxxxxxxxxxx
GOTONG_LARK_APP_SECRET=
# Slack（Socket Mode，需 app-level + bot 两个 token，免穿透）：
# GOTONG_SLACK_APP_TOKEN=              # xapp-...
# GOTONG_SLACK_BOT_TOKEN=              # xoxb-...
# QQ（官方 Bot；★ 入站 webhook，需公网域名+SSL，家用 T1 不适用 → 见 .env.cloud）：
# GOTONG_QQ_BOT_APPID=
# GOTONG_QQ_BOT_SECRET=
#
GOTONG_IM_CHAT_CAPABILITY=chat        # 成员自由文本派给的 capability（↓ 必须有 agent 服务它）

# ── 让自由文本有人接：配一个 LLM 助手 ★ 别漏这步 ★ ───────────────
# host【不】从 env 读 LLM key。IM 接通后还要有一个 agent 服务上面那个
# capability，否则成员发消息会「无人服务」。host 起来后开 admin UI
# （首启 URL 打印在终端），在「Agents」建一个 capability=chat 的 LLM
# agent，填 provider / baseURL / model / apiKey（如 openai-compatible
# + 你服务商的端点）。真 key 只在这里填，不进任何模板文件。
# 详见 docs/zh/GO-LIVE.md。

# ── 凭证库主密钥 ────────────────────────────────────────────────
# 家用主机你物理可控，默认 local-file 即可（密钥存 <GOTONG_SPACE>/identity-master.key）。
# 不设这两行 = 用默认。云服务器才需要换成 env provider（见 .env.cloud）。
# GOTONG_MASTER_KEY_PROVIDER=local-file

# ── 语言 / 日志 ─────────────────────────────────────────────────
GOTONG_DEFAULT_LANG=zh                 # zh | en
GOTONG_LOG_FORMAT=pretty               # 终端跑：pretty；交给 journald/docker：json
