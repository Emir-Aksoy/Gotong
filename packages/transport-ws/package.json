{
  "name": "@aipehub/transport-ws",
  "version": "3.1.0",
  "type": "module",
  "description": "AipeHub Hub-side WebSocket transport. Lets remote agents connect via the wire protocol.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Emir-Aksoy/AipeHub.git",
    "directory": "packages/transport-ws"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepack": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@aipehub/core": "workspace:*",
    "@aipehub/protocol": "workspace:*",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "@types/ws": "^8.5.13",
    "vitest": "^4.1.7"
  }
}
