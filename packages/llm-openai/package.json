{
  "name": "@gotong/llm-openai",
  "version": "3.1.0",
  "type": "module",
  "description": "Gotong LLM provider for OpenAI — wraps openai and implements LlmProvider.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Emir-Aksoy/Gotong.git",
    "directory": "packages/llm-openai"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepack": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@gotong/llm": "workspace:*"
  },
  "peerDependencies": {
    "openai": "^6.38.0"
  },
  "devDependencies": {
    "openai": "^6.38.0",
    "vitest": "^4.1.10"
  }
}
