{
  "name": "@aipehub/workflow",
  "version": "0.1.0",
  "type": "module",
  "description": "AipeHub workflow runner — pluggable, file-first multi-step orchestration that lives outside the Hub core.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/AipeHub/AipeHub.git",
    "directory": "packages/workflow"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "src", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepack": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@aipehub/core": "workspace:*",
    "yaml": "^2.5.0"
  },
  "devDependencies": {
    "vitest": "^2.0.0"
  }
}
