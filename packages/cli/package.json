{
  "name": "@gotong/cli",
  "version": "1.0.0",
  "type": "module",
  "description": "Gotong CLI — bootstrap sidecar agents, ping a hub, inspect services. Zero install needed beyond `npx @gotong/cli`.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Emir-Aksoy/Gotong.git",
    "directory": "packages/cli"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "gotong": "./bin/gotong.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "bin",
    "templates",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepack": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@gotong/core": "workspace:*",
    "@gotong/protocol": "workspace:*",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "vitest": "^3.2.4",
    "@types/ws": "^8.5.13"
  }
}
