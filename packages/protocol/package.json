{
  "name": "@aipehub/protocol",
  "version": "2.0.0",
  "type": "module",
  "description": "AipeHub wire protocol — frame types, constants, and codec. Zero runtime.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/AipeHub/AipeHub.git",
    "directory": "packages/protocol"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "src", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepack": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@aipehub/core": "workspace:*"
  }
}
