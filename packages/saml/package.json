{
  "name": "@gotong/saml",
  "version": "0.1.0",
  "type": "module",
  "description": "Gotong SAML 2.0 SP protocol core — AuthnRequest generation, SAMLResponse/Assertion parsing, XML-DSig signature validation (xml-crypto) with explicit signature-wrapping (XSW) guards, and condition validation. Pure functions; the host glue drives the redirect/ACS round-trip and identity owns account linking.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Emir-Aksoy/Gotong.git",
    "directory": "packages/saml"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@xmldom/xmldom": "^0.8.10",
    "xml-crypto": "^6.0.0",
    "xpath": "^0.0.34"
  },
  "devDependencies": {
    "vitest": "^4.1.10"
  }
}
