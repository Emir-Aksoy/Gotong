{
  "name": "@gotong/im-lark",
  "version": "0.1.0",
  "type": "module",
  "description": "Gotong IM bridge for Lark / Feishu — implements ImBridge over the OFFICIAL long connection (@larksuiteoapi/node-sdk WSClient). Outbound, works behind NAT (no public webhook). Sends still go through the REST client (fetch). Card-button callbacks are not delivered over the long connection.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Emir-Aksoy/Gotong.git",
    "directory": "packages/im-lark"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@gotong/im-adapter": "workspace:*",
    "@larksuiteoapi/node-sdk": "^1.70.0"
  },
  "devDependencies": {
    "vitest": "^3.2.4"
  }
}
