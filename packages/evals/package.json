{
  "name": "@gotong/evals",
  "version": "0.1.0",
  "type": "module",
  "description": "Gotong workflow + agent prompt eval harness — lightweight structural checkers that catch output-format regressions without burning LLM tokens.",
  "license": "MIT",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./checkers/three-segment": {
      "types": "./dist/checkers/three-segment.d.ts",
      "import": "./dist/checkers/three-segment.js"
    },
    "./checkers/structure": {
      "types": "./dist/checkers/structure.d.ts",
      "import": "./dist/checkers/structure.js"
    },
    "./checkers/workflow-structure": {
      "types": "./dist/checkers/workflow-structure.d.ts",
      "import": "./dist/checkers/workflow-structure.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@gotong/workflow": "workspace:*"
  },
  "devDependencies": {
    "vitest": "^3.2.4"
  }
}
