{
  "name": "@aipehub/host",
  "version": "3.1.0",
  "type": "module",
  "description": "Production host binary for AipeHub — runs Hub + WebSocket + Web from environment variables. No demo state, no built-in agents.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Emir-Aksoy/AipeHub.git",
    "directory": "packages/host"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "aipehub-host": "./bin/aipehub-host.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./services": {
      "types": "./dist/services/index.d.ts",
      "import": "./dist/services/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "bin",
    "scripts",
    "README.md"
  ],
  "scripts": {
    "build": "node scripts/build-version.mjs && tsc -p tsconfig.json",
    "build:version": "node scripts/build-version.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "tsx src/main.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepack": "node scripts/build-version.mjs && tsc -p tsconfig.json"
  },
  "dependencies": {
    "@aipehub/core": "workspace:*",
    "@aipehub/identity": "workspace:*",
    "@aipehub/llm": "workspace:*",
    "@aipehub/llm-anthropic": "workspace:*",
    "@aipehub/llm-openai": "workspace:*",
    "@aipehub/mcp-client": "workspace:*",
    "@aipehub/protocol": "workspace:*",
    "@aipehub/service-artifact-file": "workspace:*",
    "@aipehub/service-datastore-sqlite": "workspace:*",
    "@aipehub/service-memory-file": "workspace:*",
    "@aipehub/services-sdk": "workspace:*",
    "@aipehub/transport-ws": "workspace:*",
    "@aipehub/web": "workspace:*",
    "@aipehub/workflow": "workspace:*",
    "@aipehub/workflow-assistant": "workspace:*",
    "@anthropic-ai/sdk": "^0.96.0",
    "openai": "^6.38.0",
    "better-sqlite3": "^12.10.0"
  },
  "devDependencies": {
    "@aipehub/sdk-node": "workspace:*",
    "vitest": "^3.2.4"
  }
}
