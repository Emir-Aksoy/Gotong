{
  "name": "@gotong/host",
  "version": "3.2.0",
  "type": "module",
  "description": "Production host binary for Gotong — runs Hub + WebSocket + Web from environment variables. No demo state, no built-in agents.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Emir-Aksoy/Gotong.git",
    "directory": "packages/host"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "gotong-host": "./bin/gotong-host.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./services": {
      "types": "./dist/services/index.d.ts",
      "import": "./dist/services/index.js"
    },
    "./mcp-proxy": {
      "types": "./dist/mcp-proxy.d.ts",
      "import": "./dist/mcp-proxy.js"
    },
    "./check": {
      "types": "./dist/workspace-check.d.ts",
      "import": "./dist/workspace-check.js"
    },
    "./ops": {
      "types": "./dist/ops-core.d.ts",
      "import": "./dist/ops-core.js"
    },
    "./routing-health": {
      "types": "./dist/routing-health.d.ts",
      "import": "./dist/routing-health.js"
    }
  },
  "files": [
    "dist",
    "src",
    "bin",
    "scripts",
    "README.md"
  ],
  "scripts": {
    "build": "node scripts/build-version.mjs && tsc -p tsconfig.json",
    "build:version": "node scripts/build-version.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "tsx src/main.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepack": "node scripts/build-version.mjs && tsc -p tsconfig.json"
  },
  "dependencies": {
    "@gotong/a2a": "workspace:*",
    "@gotong/acp-agent": "workspace:*",
    "@gotong/core": "workspace:*",
    "@gotong/evals": "workspace:*",
    "@gotong/hub-steward": "workspace:*",
    "@gotong/identity": "workspace:*",
    "@gotong/im-adapter": "workspace:*",
    "@gotong/im-lark": "workspace:*",
    "@gotong/im-qq": "workspace:*",
    "@gotong/im-slack": "workspace:*",
    "@gotong/im-telegram": "workspace:*",
    "@gotong/im-wechat": "workspace:*",
    "@gotong/inbox": "workspace:*",
    "@gotong/llm": "workspace:*",
    "@gotong/llm-anthropic": "workspace:*",
    "@gotong/llm-openai": "workspace:*",
    "@gotong/mcp-client": "workspace:*",
    "@gotong/personal-butler": "workspace:*",
    "@gotong/personal-memory": "workspace:*",
    "@gotong/protocol": "workspace:*",
    "@gotong/saml": "workspace:*",
    "@gotong/service-artifact-file": "workspace:*",
    "@gotong/service-datastore-sqlite": "workspace:*",
    "@gotong/service-memory-file": "workspace:*",
    "@gotong/services-sdk": "workspace:*",
    "@gotong/transport-ws": "workspace:*",
    "@gotong/web": "workspace:*",
    "@gotong/workflow": "workspace:*",
    "@gotong/workflow-assistant": "workspace:*",
    "@anthropic-ai/sdk": "^0.111.0",
    "openai": "^6.46.0",
    "better-sqlite3": "^12.11.1",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@gotong/cli": "workspace:*",
    "@gotong/cli-agent": "workspace:*",
    "@gotong/sdk-node": "workspace:*",
    "@types/ws": "^8.5.13",
    "vitest": "^3.2.4"
  }
}
