{
  "name": "@gotong/cli-agent",
  "version": "0.1.0",
  "type": "module",
  "description": "Gotong outbound CLI shell-out adapter — wraps a self-hosted coding-agent CLI (Claude Code / Codex / OpenCode / Aider …) as a hub Participant, with a checkpoint loop + cooperative on-demand park so a person can observe / intercept / hand off / resume / terminate the task (AGENT-ADAPTER-CONTRACT).",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Emir-Aksoy/Gotong.git",
    "directory": "packages/cli-agent"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@gotong/core": "workspace:*"
  },
  "devDependencies": {
    "vitest": "^3.2.4"
  }
}
