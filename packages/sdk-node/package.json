{
  "name": "@gotong/sdk-node",
  "version": "4.0.0",
  "type": "module",
  "description": "Gotong Node SDK — connect agents to a remote Hub over WebSocket.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Emir-Aksoy/Gotong.git",
    "directory": "packages/sdk-node"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepack": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@gotong/core": "workspace:*",
    "@gotong/protocol": "workspace:*",
    "@gotong/services-sdk": "workspace:*",
    "ws": "^8.21.1"
  },
  "devDependencies": {
    "@gotong/transport-ws": "workspace:*",
    "@types/ws": "^8.5.13",
    "vitest": "^4.1.10"
  }
}
