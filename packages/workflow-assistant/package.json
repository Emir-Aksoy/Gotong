{
  "name": "@aipehub/workflow-assistant",
  "version": "0.1.0",
  "type": "module",
  "description": "AipeHub workflow assistant — LlmAgent that turns a natural-language description into an aipehub.workflow/v1 YAML draft. Lives outside @aipehub/workflow so the runner stays free of any LLM runtime dependency.",
  "license": "MIT",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aipehub/core": "workspace:*",
    "@aipehub/llm": "workspace:*",
    "@aipehub/workflow": "workspace:*"
  },
  "devDependencies": {
    "vitest": "^3.2.4"
  }
}
