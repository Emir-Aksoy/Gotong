{
  "name": "@gotong/workflow-assistant",
  "version": "0.1.0",
  "type": "module",
  "description": "Gotong workflow assistant — LlmAgent that turns a natural-language description into an gotong.workflow/v1 YAML draft. Lives outside @gotong/workflow so the runner stays free of any LLM runtime dependency.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Emir-Aksoy/Gotong.git",
    "directory": "packages/workflow-assistant"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "templates",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@gotong/core": "workspace:*",
    "@gotong/evals": "workspace:*",
    "@gotong/llm": "workspace:*",
    "@gotong/workflow": "workspace:*"
  },
  "devDependencies": {
    "vitest": "^3.2.4"
  }
}
