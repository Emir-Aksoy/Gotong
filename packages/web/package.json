{
  "name": "@aipehub/web",
  "version": "2.0.0",
  "type": "module",
  "description": "AipeHub reference web UI — embeddable HTTP + SSE server with a vanilla-JS frontend.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Emir-Aksoy/AipeHub.git",
    "directory": "packages/web"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "src", "static", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepack": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@aipehub/core": "workspace:*",
    "@aipehub/protocol": "workspace:*",
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "vitest": "^2.0.0"
  }
}
