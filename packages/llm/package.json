{
  "name": "@aipehub/llm",
  "version": "2.0.0",
  "type": "module",
  "description": "AipeHub LLM agent base — provider interface and LlmAgent for building LLM-backed participants.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/AipeHub/AipeHub.git",
    "directory": "packages/llm"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "src", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepack": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@aipehub/core": "workspace:*"
  },
  "devDependencies": {
    "vitest": "^4.1.6"
  }
}
