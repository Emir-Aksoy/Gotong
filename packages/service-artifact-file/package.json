{
  "name": "@gotong/service-artifact-file",
  "version": "4.0.0",
  "type": "module",
  "description": "Gotong artifact service — file-backed implementation. Stores markdown / json / binary artifacts under per-owner directories with path-traversal protection.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Emir-Aksoy/Gotong.git",
    "directory": "packages/service-artifact-file"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepack": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@gotong/services-sdk": "workspace:*",
    "@gotong/core": "workspace:*"
  },
  "devDependencies": {
    "vitest": "^4.1.10"
  }
}
