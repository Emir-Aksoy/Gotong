{
  "name": "@aipehub/service-artifact-file",
  "version": "0.1.0",
  "type": "module",
  "description": "AipeHub artifact service — file-backed implementation. Stores markdown / json / binary artifacts under per-owner directories with path-traversal protection.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Emir-Aksoy/AipeHub.git",
    "directory": "packages/service-artifact-file"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "src", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepack": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@aipehub/services-sdk": "workspace:*",
    "@aipehub/core": "workspace:*"
  },
  "devDependencies": {
    "vitest": "^4.1.6"
  }
}
