{
  "name": "@aipehub/llm-anthropic",
  "version": "3.1.0",
  "type": "module",
  "description": "AipeHub LLM provider for Anthropic — wraps @anthropic-ai/sdk and implements LlmProvider.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Emir-Aksoy/AipeHub.git",
    "directory": "packages/llm-anthropic"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepack": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@aipehub/llm": "workspace:*"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": "^0.96.0"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.96.0",
    "vitest": "^3.2.4"
  }
}
